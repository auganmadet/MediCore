# ==================== ENVIRONNEMENT ====================
# dev | prod
ENV=dev

# ==================== Snowflake ====================
SNOWFLAKE_ACCOUNT=XXXXX-YYYYY
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE_NAME=MEDICORE_WH
SNOWFLAKE_DATABASE=MEDICORE
SNOWFLAKE_SCHEMA_NAME=RAW
SNOWFLAKE_ROLE_NAME=MEDICORE_RAW_WRITER
SNOWFLAKE_DBT_ROLE_NAME=MEDICORE_DBT_EXECUTOR

# ==================== MySQL Winstat ====================
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=winstat

# ==================== Kafka/Debezium ====================
# Utiliser localhost:9092 hors Docker, kafka:9092 dans Docker
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
CONNECTOR_NAME=winstat-rds

# ==================== dbt ====================
DBT_PROFILES_DIR=/app/dbt

# ==================== Pipeline ====================
# Heure du rechargement reference (00-23)
REF_RELOAD_HOUR=03
# Seuil d'alerte (nombre d'echecs consecutifs)
ALERT_THRESHOLD=3
# Timeout consumer CDC en secondes
CDC_BATCH_TIMEOUT_SEC=30

# ==================== Alertes ====================
TEAMS_WEBHOOK_URL=
